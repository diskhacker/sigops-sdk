{
  "name": "@sigops/cli",
  "version": "1.0.0",
  "description": "CLI for SigOps SDK - init, test, validate, publish tools and templates",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sigops": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/diskhacker/sigops-sdk.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsc --outDir dist --declaration",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": ["sigops", "cli", "sdk"],
  "license": "MIT"
}
