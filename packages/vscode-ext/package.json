{
  "name": "@sigops/vscode-ext",
  "version": "0.1.0",
  "description": "VS Code extension for SigOps Expression Language (SEL)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --outDir dist --declaration",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": ["sigops", "vscode", "sel", "extension"],
  "license": "MIT"
}
