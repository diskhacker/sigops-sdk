{
  "name": "@sigops/vscode-ext",
  "version": "1.0.0",
  "description": "VS Code extension for SigOps Expression Language (SEL)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/diskhacker/sigops-sdk.git",
    "directory": "packages/vscode-ext"
  },
  "scripts": {
    "build": "tsc --outDir dist --declaration",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": ["sigops", "vscode", "sel", "extension"],
  "license": "MIT"
}
