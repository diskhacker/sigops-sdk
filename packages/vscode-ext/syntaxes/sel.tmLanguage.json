{
  "scopeName": "source.sel",
  "name": "SEL",
  "fileTypes": ["sel"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.sel", "match": "//.*$" },
        { "name": "comment.block.sel", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.sel", "match": "\\b(monitor|alert|action|when|then|else)\\b" },
        { "name": "constant.language.sel", "match": "\\b(true|false|null)\\b" },
        { "name": "keyword.other.sel", "match": "\\b(threshold|interval|target|timeout|escalate_after|pre_check|on_failure|notify|severity)\\b" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sel",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.sel", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.sel", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.sel", "match": "(>=|<=|==|!=|>|<)" },
        { "name": "keyword.operator.arithmetic.sel", "match": "[+\\-*/]" }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.definition.block.sel", "match": "[{}]" },
        { "name": "punctuation.definition.parameters.sel", "match": "[()]" },
        { "name": "punctuation.separator.sel", "match": "[:,.]" }
      ]
    }
  }
}
